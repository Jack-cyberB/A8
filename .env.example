LLM_ENABLE_TEMPLATE_FALLBACK=0

RAGFLOW_BASE_URL=http://127.0.0.1:8088/api/v1
RAGFLOW_WEB_BASE_URL=http://127.0.0.1:8088
RAGFLOW_API_KEY=YOUR_RAGFLOW_API_KEY
RAGFLOW_DATASET_IDS=YOUR_SCENE_DATASET_ID
RAGFLOW_STANDARD_DATASET_IDS=YOUR_STANDARD_DATASET_ID
RAGFLOW_CHAT_ID=YOUR_CHAT_ID
RAGFLOW_SHARED_DIALOG_ID=YOUR_CHAT_ID
